# Django
DOCKER_SECRET_KEY=django-insecure-dev-docker-change-me
DOCKER_DEBUG=True
DOCKER_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL inside Docker network
POSTGRES_DB=erp_ventas_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DB_ENGINE=django.db.backends.postgresql
DB_NAME=erp_ventas_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_WAIT_TIMEOUT=180
DOCKER_CSRF_TRUSTED_ORIGINS=http://localhost:8000
SECURE_PROXY_SSL_HEADER=True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Development bootstrap
RUN_MIGRATIONS=True
RUN_COLLECTSTATIC=True
RUN_SEED=True
SEED_ONLY_IF_EMPTY=True
SEED_CLIENTS=20
SEED_PRODUCTS=30
SEED_ORDERS=20
SEED_SALES=10
SEED_CLAIMS=10

DOCKER_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
